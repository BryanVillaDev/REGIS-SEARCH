# Copy this file to .env and fill real values locally.
# Do not commit production secrets.

APP_ENV=local
APP_TIMEZONE=America/Bogota
JWT_SECRET=change-me-use-a-long-random-secret

# API key para endpoints maquina-a-maquina sin JWT (header X-API-Key).
# Si queda vacia, esos endpoints responden 503.
REGIS_API_KEY=change-me-long-random-api-key

# ClickHouse HTTP endpoint. Prefer an internal/private endpoint in production.
CLICKHOUSE_URL=http://your-clickhouse-host:80
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=change-me
CLICKHOUSE_DATABASE=app
CLICKHOUSE_SECURE=false

# Bootstrap creates the first admin if the username does not exist.
REGIS_BOOTSTRAP_ADMIN_USER=admin
REGIS_BOOTSTRAP_ADMIN_PASSWORD=change-me-before-starting

EXPORT_DIR=/exports
WORKER_POLL_SECONDS=3
QUERY_TIMEOUT_SECONDS=30
BULK_CHUNK_SIZE=5000
XLSX_MAX_ROWS=200000

VITE_API_BASE_URL=/api
