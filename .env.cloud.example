# Credenciales del ClickHouse CLOUD de origen (para la sincronizacion).
# Copia este archivo a .env.cloud y pon las credenciales reales. NO commitear el real.
#   cp .env.cloud.example .env.cloud
CLOUD_CH_HOST=158.69.43.197
CLOUD_CH_PORT=9000
# Puerto HTTP del cloud (el sync usa HTTP, no el nativo 9000). Normalmente 8123.
CLOUD_CH_HTTP_PORT=8123
CLOUD_CH_USER=default
CLOUD_CH_PASSWORD=rotar-esta-clave
# Bases a migrar, separadas por coma (autodescubre las tablas de cada una).
CLOUD_CH_DATABASES=ani
