# Credenciales del ClickHouse CLOUD de origen (para la sincronizacion).
# Copia este archivo a .env.cloud y pon los valores reales. NO commitear el real.
#   cp .env.cloud.example .env.cloud
#
# El sync usa HTTP. Si el ClickHouse esta detras de Traefik/Dokploy, el host es el
# dominio publico y el puerto es 80 (NO 8123 ni el nativo 9000).
# Ej: mi-clickhouse-xxxx.traefik.me  +  CLOUD_CH_HTTP_PORT=80
CLOUD_CH_HOST=tu-clickhouse.ejemplo.traefik.me
CLOUD_CH_HTTP_PORT=80
CLOUD_CH_USER=default
CLOUD_CH_PASSWORD=rotar-esta-clave
# Bases a migrar, separadas por coma (autodescubre las tablas de cada una).
CLOUD_CH_DATABASES=ani
